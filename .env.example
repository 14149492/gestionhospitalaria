# Variables de Entorno Requeridas
# Copiar este archivo como .env.local y completar los valores reales

# Supabase - URL del proyecto
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co

# Supabase - Publishable Key (clave pública/anon)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxx

# Supabase - Service Role Key (SOLO en el servidor, NUNCA exponer en el cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxx

# Cadena de conexión directa a PostgreSQL (opcional, para Prisma/migraciones)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxxxxxxxxx.supabase.co:5432/postgres
